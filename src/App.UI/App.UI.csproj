<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <RootNamespace>App.UI</RootNamespace>
    <AssemblyName>EpicRpf</AssemblyName>
    <ApplicationIcon></ApplicationIcon>
    <!-- WindowsDesktop 10 is the only desktop runtime installed; target it directly. -->
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\App.Core\App.Core.csproj" />
    <ProjectReference Include="..\App.Geometry\App.Geometry.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- The HTML/CSS/JS front-end, served to WebView2 via a virtual host mapping. -->
    <Content Include="wwwroot\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3967.48" />
  </ItemGroup>

</Project>
